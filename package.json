{
  "name": "vendix",
  "version": "1.0.5",
  "description": "Sistema de PDV para pequenos negÃ³cios",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.vendix.app",
    "productName": "Vendix",
    "copyright": "Copyright Â© 2026 Vendix",
    "publish": {
      "provider": "generic",
      "url": "https://vendix-production-5c8b.up.railway.app/download/updates"
    },
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Vendix",
      "include": "build/installer.nsh"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**",
      "node_modules/**"
    ]
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
